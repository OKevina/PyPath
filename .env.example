# Prisma SQLite database
DATABASE_URL="file:./dev.db"

# --- GitHub progress sync (optional) ---
# Push your progress to a dedicated GitHub repo after each first-solve.
# Requires the GitHub CLI installed and authenticated: `gh auth login`.
#
# 1. Create an empty repo on GitHub (e.g. OKevina/pypath-progress)
# 2. Set the two values below and restart the server.
GITHUB_SYNC=off
GITHUB_PROGRESS_REPO=OKevina/pypath-progress
